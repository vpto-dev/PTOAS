module attributes {pto.target_arch = "a5"} {
  func.func @fixpipe_quant_ub_cv_kernel_mix_aiv(%a_gm: !pto.ptr<f16, gm>,
                                                %b_gm: !pto.ptr<f16, gm>,
                                                %fp_gm: !pto.ptr<f32, gm>,
                                                %out_gm: !pto.ptr<f16, gm>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0_i64 = arith.constant 0 : i64
    %c64_i64 = arith.constant 64 : i64
    %c8_i64 = arith.constant 8 : i64

    %ub_out = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, ub>
    %subblock = pto.get_subblock_idx
    %is_subblock0 = arith.cmpi eq, %subblock, %c0_i64 : i64

    scf.if %is_subblock0 {
      pto.sync.wait <PIPE_MTE3>, 1
      pto.dma_store %ub_out, %out_gm, %c64_i64
        nburst(%c8_i64, %c64_i64, %c64_i64)
        : !pto.ptr<f16, ub>, !pto.ptr<f16, gm>, i64, i64, i64, i64
    }
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
